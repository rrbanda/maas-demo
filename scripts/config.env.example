# AI Bridge (MaaS) Demo Configuration
# Copy this file to config.env and fill in your cluster details.

# --- Cluster Contexts (from 'oc config get-contexts') ---
# Inference cluster: where the model runs (needs GPU)
CTX_INFERENCE="default/api-<inference-cluster>:6443/admin"
# Gateway cluster: where the AI gateway runs (CPU only, optional for multi-cluster)
CTX_GATEWAY="default/api-<gateway-cluster>:6443/admin"

# --- Model Configuration ---
MODEL_NAME="qwen25-7b-instruct"
MODEL_NS="llm-inference"

# --- Multi-Cluster Routing ---
# The route hostname for the model on the inference cluster
# Example: qwen25-7b-inference-llm-inference.apps.<inference-cluster-domain>
REMOTE_MODEL_HOSTNAME="REPLACE_WITH_REMOTE_MODEL_HOSTNAME"

# --- MaaS Gateway ---
# The internal service hostname for the MaaS gateway
MAAS_GW_SVC="maas-default-gateway-data-science-gateway-class.openshift-ingress.svc:443"

# --- Guardrails ---
# The route hostname for the guardrails gateway
# Example: guardrails-gateway-ai-guardrails.apps.<inference-cluster-domain>
GUARDRAILS_HOST="REPLACE_WITH_GUARDRAILS_ROUTE"

# --- vLLM Service (for guardrails proxy) ---
# The internal service hostname for vLLM
# Example: qwen25-7b-instruct-kserve-workload-svc.llm-inference.svc:8000
VLLM_SERVICE="REPLACE_WITH_VLLM_SERVICE"

# --- OIDC / Keycloak ---
# Keycloak host (route hostname)
# Example: keycloak-keycloak.apps.<gateway-cluster-domain>
KEYCLOAK_HOST="REPLACE_WITH_KEYCLOAK_HOST"
KEYCLOAK_REALM="ai-bridge"
OIDC_CLIENT_ID="ai-bridge-gateway"
OIDC_CLIENT_SECRET="REPLACE_WITH_OIDC_CLIENT_SECRET"

# --- Vault ---
VAULT_TOKEN="REPLACE_WITH_VAULT_TOKEN"
